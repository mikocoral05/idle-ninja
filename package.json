{
  "name": "idle-ninja",
  "version": "1.0.1",
  "description": "The High-Performance, Cross-Tab Inactivity Tracker built for modern web applications.",
  "main": "dist/idle-ninja.js",
  "types": "dist/idle-ninja.d.ts",
  "unpkg": "dist/idle-ninja.browser.min.js",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "test": "jest",
    "build": "tsc && rollup -c",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "mikael_tenshio",
  "repository": {
    "type": "git",
    "url": "https://github.com/mikocoral05/idle-ninja.git"
  },
  "funding": [
    {
      "type": "ko-fi",
      "url": "https://ko-fi.com/mikaeltenshio"
    },
    {
      "type": "buymeacoffee",
      "url": "https://buymeacoffee.com/mikaeltenshio"
    }
  ],
  "license": "ISC",
  "devDependencies": {
    "@commitlint/cli": "^19.2.1",
    "@commitlint/config-conventional": "^19.1.0",
    "@playwright/test": "^1.42.0",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/jest": "^29.5.12",
    "@typescript-eslint/eslint-plugin": "^7.1.0",
    "@typescript-eslint/parser": "^7.1.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.2.5",
    "rollup": "^4.60.2",
    "ts-jest": "^29.1.2",
    "tslib": "^2.8.1",
    "typescript": "^5.0.0",
    "vite": "^5.2.0"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,html,yml}": "prettier --write"
  },
  "overrides": {
    "@tootallnate/once": "^3.0.1",
    "esbuild": "^0.24.2"
  }
}
